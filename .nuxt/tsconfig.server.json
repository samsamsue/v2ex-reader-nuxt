{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "~/*": [
        "../*"
      ],
      "@/*": [
        "../*"
      ],
      "~~/*": [
        "../*"
      ],
      "@@/*": [
        "../*"
      ],
      "@unhead/vue": [
        "../node_modules/.store/@unhead+vue@2.1.12/node_modules/@unhead/vue"
      ],
      "@nuxt/devtools": [
        "../node_modules/.store/@nuxt+devtools@3.2.4/node_modules/@nuxt/devtools"
      ],
      "vue": [
        "../node_modules/.store/vue@3.5.32/node_modules/vue"
      ],
      "@vue/runtime-core": [
        "../node_modules/.store/@vue+runtime-core@3.5.32/node_modules/@vue/runtime-core"
      ],
      "@vue/compiler-sfc": [
        "../node_modules/.store/@vue+compiler-sfc@3.5.32/node_modules/@vue/compiler-sfc"
      ],
      "vue-router": [
        "../node_modules/.store/vue-router@4.6.4/node_modules/vue-router"
      ],
      "vue-router/auto-routes": [
        "../node_modules/.store/vue-router@4.6.4/node_modules/vue-router/vue-router-auto-routes"
      ],
      "unplugin-vue-router/client": [
        "../node_modules/.store/unplugin-vue-router@0.19.2/node_modules/unplugin-vue-router/client"
      ],
      "@nuxt/schema": [
        "../node_modules/.store/@nuxt+schema@3.21.2/node_modules/@nuxt/schema"
      ],
      "nuxt": [
        "../node_modules/.store/nuxt@3.21.2/node_modules/nuxt"
      ],
      "vite/client": [
        "../node_modules/.store/vite@7.3.1/node_modules/vite/client"
      ],
      "nitropack/types": [
        "../node_modules/.store/nitropack@2.13.3/node_modules/nitropack/types"
      ],
      "nitropack/runtime": [
        "../node_modules/.store/nitropack@2.13.3/node_modules/nitropack/runtime"
      ],
      "nitropack": [
        "../node_modules/.store/nitropack@2.13.3/node_modules/nitropack"
      ],
      "defu": [
        "../node_modules/.store/defu@6.1.6/node_modules/defu"
      ],
      "h3": [
        "../node_modules/.store/h3@1.15.11/node_modules/h3"
      ],
      "consola": [
        "../node_modules/.store/consola@3.4.2/node_modules/consola"
      ],
      "ofetch": [
        "../node_modules/.store/ofetch@1.5.1/node_modules/ofetch"
      ],
      "crossws": [
        "../node_modules/.store/crossws@0.4.4/node_modules/crossws"
      ],
      "#shared": [
        "../shared"
      ],
      "#shared/*": [
        "../shared/*"
      ],
      "assets": [
        "../assets"
      ],
      "assets/*": [
        "../assets/*"
      ],
      "public": [
        "../public"
      ],
      "public/*": [
        "../public/*"
      ],
      "#server": [
        "../server"
      ],
      "#server/*": [
        "../server/*"
      ],
      "#build": [
        "./"
      ],
      "#build/*": [
        "./*"
      ],
      "#internal/nuxt/paths": [
        "../node_modules/.store/@nuxt+nitro-server@3.21.2/node_modules/@nuxt/nitro-server/dist/runtime/utils/paths"
      ],
      "#unhead/composables": [
        "../node_modules/.store/nuxt@3.21.2/node_modules/nuxt/dist/head/runtime/composables/v3"
      ]
    },
    "lib": [
      "esnext",
      "webworker",
      "dom.iterable"
    ],
    "noUncheckedIndexedAccess": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "./types/nitro-nuxt.d.ts",
    "../node_modules/.store/@nuxt+devtools@3.2.4/node_modules/runtime/server",
    "../node_modules/.store/@nuxt+devtools@3.2.4/node_modules/dist/runtime/server",
    "../node_modules/.store/@nuxt+telemetry@2.8.0/node_modules/runtime/server",
    "../node_modules/.store/@nuxt+telemetry@2.8.0/node_modules/dist/runtime/server",
    "../server/**/*",
    "../shared/**/*.d.ts",
    "./types/nitro.d.ts",
    "../**/*"
  ],
  "exclude": [
    "../node_modules",
    "../node_modules/.store/nuxt@3.21.2/node_modules/nuxt/node_modules",
    "../node_modules/.store/@nuxt+devtools@3.2.4/node_modules/@nuxt/devtools/node_modules",
    "../node_modules/.store/@nuxt+telemetry@2.8.0/node_modules/@nuxt/telemetry/node_modules",
    "../dist"
  ]
}