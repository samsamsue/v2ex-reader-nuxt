{
  "name": "linuxdo-reader-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');for(const dir of ['.nuxt','.output'])fs.rmSync(dir,{recursive:true,force:true})\"",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "rebuild": "npm run clean && npm run build",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "markdown-it": "^14.1.0",
    "nuxt": "^3.12.4",
    "qrcode": "^1.5.4",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "sass-embedded": "^1.99.0"
  }
}
